{
  "expectation_suite_name": "gold_fact_orders",
  "expectations": [
    {"expectation_type": "expect_column_values_to_not_be_null", "kwargs": {"column": "order_sk"}},
    {"expectation_type": "expect_column_values_to_be_unique", "kwargs": {"column": "order_sk"}},
    {"expectation_type": "expect_column_values_to_not_be_null", "kwargs": {"column": "order_id"}},
    {"expectation_type": "expect_column_values_to_be_unique", "kwargs": {"column": "order_id"}},
    {"expectation_type": "expect_column_values_to_not_be_null", "kwargs": {"column": "user_id"}},
    {"expectation_type": "expect_column_values_to_not_be_null", "kwargs": {"column": "order_date_sk"}},
    {
      "expectation_type": "expect_column_values_to_be_between",
