# =============================================================================
# MeliSimLake — variáveis de ambiente
# Copie para .env e preencha os valores reais.
# NUNCA commite o arquivo .env.
# =============================================================================

# -----------------------------------------------------------------------------
# MinIO (S3 local)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MELISIMLAKE_MINIO_ENDPOINT=http://minio:9000
MELISIMLAKE_MINIO_ACCESS_KEY=minioadmin
MELISIMLAKE_MINIO_SECRET_KEY=minioadmin123

# -----------------------------------------------------------------------------
# PostgreSQL — Airflow metadata
# -----------------------------------------------------------------------------
POSTGRES_AIRFLOW_HOST=postgres-airflow
POSTGRES_AIRFLOW_PORT=5432
POSTGRES_AIRFLOW_DB=airflow
POSTGRES_AIRFLOW_USER=airflow
POSTGRES_AIRFLOW_PASSWORD=airflow123
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow123@postgres-airflow:5432/airflow

# -----------------------------------------------------------------------------
# PostgreSQL — MLflow metadata
# -----------------------------------------------------------------------------
POSTGRES_MLFLOW_HOST=postgres-mlflow
POSTGRES_MLFLOW_PORT=5432
POSTGRES_MLFLOW_DB=mlflow
POSTGRES_MLFLOW_USER=mlflow
POSTGRES_MLFLOW_PASSWORD=mlflow123
MLFLOW_BACKEND_STORE_URI=postgresql://mlflow:mlflow123@postgres-mlflow:5432/mlflow
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts/
MELISIMLAKE_MLFLOW_TRACKING_URI=http://mlflow:5000

# -----------------------------------------------------------------------------
# PostgreSQL — Feast online store
# -----------------------------------------------------------------------------
POSTGRES_FEAST_HOST=postgres-feast
POSTGRES_FEAST_PORT=5432
POSTGRES_FEAST_DB=feast
POSTGRES_FEAST_USER=feast
POSTGRES_FEAST_PASSWORD=feast123

# -----------------------------------------------------------------------------
# Kafka / Schema Registry
# -----------------------------------------------------------------------------
MELISIMLAKE_KAFKA_BOOTSTRAP_SERVERS=melisimlake-kafka:9092
KAFKA_BOOTSTRAP_SERVERS=melisimlake-kafka:9092
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLt0nIe3aI=
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=false
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow123@postgres-airflow:5432/airflow
AIRFLOW__CELERY__BROKER_URL=redis://redis-airflow:6379/0
AIRFLOW__WEBSERVER__SECRET_KEY=melisimlake-secret-key-change-me
AIRFLOW_UID=50000

# -----------------------------------------------------------------------------
# Spark
# -----------------------------------------------------------------------------
SPARK_MASTER_URL=spark://spark-master:7077

# -----------------------------------------------------------------------------
# Trino
# -----------------------------------------------------------------------------
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_USER=admin

# -----------------------------------------------------------------------------
# MLflow
# -----------------------------------------------------------------------------
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123

# -----------------------------------------------------------------------------
# Melisim — Postgres (CDC Debezium)
# O container melisimlake-debezium precisa estar na MESMA rede Docker que o
# Postgres do Melisim (use docker-compose.melisim-network.yml — ver RUNBOOK).
# Tópicos Kafka: cdc.melisim.public.<tabela> (topic.prefix=cdc.melisim no conector JSON).
# -----------------------------------------------------------------------------
MELISIM_POSTGRES_HOST=melisim-postgres
MELISIM_POSTGRES_PORT=5432
MELISIM_POSTGRES_DB=melisim
MELISIM_POSTGRES_USER=melisim
MELISIM_POSTGRES_PASSWORD=melisim123
MELISIM_POSTGRES_TABLES=public.products,public.payments,public.notifications

# REST do Kafka Connect (host — register.sh usa por defeito)
DEBEZIUM_URL=http://localhost:8083

MELISIM_API_BASE_URL=http://api-gateway:8000

# -----------------------------------------------------------------------------
# Slack (opcional — alerts de falha de DAG)
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE/ME/PLEASE

# -----------------------------------------------------------------------------
# DataHub
# -----------------------------------------------------------------------------
DATAHUB_GMS_URL=http://datahub-gms:8080

# -----------------------------------------------------------------------------
# Prometheus / Grafana
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana123
