{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "KPIs de negócio do simulador — GMV, pedidos, sessões, eventos por categoria",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Simulador — Eventos Emitidos / min",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(melisimlake_simulator_events_total[1m]) * 60",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Simulador — Sessões Ativas",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "melisimlake_simulator_active_sessions",
          "legendFormat": "Sessões Ativas",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Simulador — Personas Ativas Hoje",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "melisimlake_simulator_personas_active",
          "legendFormat": "Personas",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Simulador — Compras por Classe de Renda",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "melisimlake_simulator_purchases_total",
          "legendFormat": "{{income_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Simulador — LLM Latência (P95, ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(melisimlake_simulator_llm_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "LLM P95",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 6,
      "title": "Simulador — Taxa de Erro LLM",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(melisimlake_simulator_llm_errors_total[5m])",
          "legendFormat": "LLM Errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Kafka — Mensagens Produzidas / min",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(kafka_server_brokertopicmetrics_messagesinpersec[1m]) * 60",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Estados Markov — Distribuição de Transições",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "melisimlake_simulator_state_transitions_total",
          "legendFormat": "{{from_state}} → {{to_state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Macro Decisions — Categoria Alvo",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "melisimlake_simulator_macro_decisions_total",
          "legendFormat": "{{target_category}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["business", "simulator", "kpis"],
  "time": {"from": "now-1h", "to": "now"},
  "title": "MeliSimLake — Business KPIs",
  "uid": "melisimlake-biz",
  "version": 1
}
