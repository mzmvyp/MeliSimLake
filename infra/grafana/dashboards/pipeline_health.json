{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Saúde do pipeline de dados — Kafka lag, Spark jobs, Airflow DAG status",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Kafka Consumer Lag — CDC Topics",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "kafka_consumer_group_lag{topic=~\"cdc.*\"}",
          "legendFormat": "{{topic}} — {{partition}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1000},
              {"color": "red", "value": 10000}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Kafka Consumer Lag — Event Topics",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "kafka_consumer_group_lag{topic=~\"events.*\"}",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Airflow DAG Success Rate (24h)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(airflow_dag_run_success_total[24h]) / (rate(airflow_dag_run_success_total[24h]) + rate(airflow_dag_run_failed_total[24h]) + 1e-9) * 100",
          "legendFormat": "Success Rate %",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["last"]}, "orientation": "horizontal"},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "green", "value": 95}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Airflow DAG Failed Runs (24h)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "increase(airflow_dag_run_failed_total[24h])",
          "legendFormat": "Failed Runs",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["last"]}},
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Spark Active Jobs",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "metrics_master_aliveWorkers",
          "legendFormat": "Active Workers",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "MinIO Disk Used",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "minio_cluster_disk_used_bytes / minio_cluster_disk_total_bytes * 100",
          "legendFormat": "Disk Used %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Bronze Records Ingested / min",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(melisimlake_cdc_records_written_total[1m]) * 60",
          "legendFormat": "CDC {{topic}}",
          "refId": "A"
        },
        {
          "expr": "rate(melisimlake_events_records_written_total[1m]) * 60",
          "legendFormat": "Events {{topic}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Spark Streaming Batch Duration",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "spark_streaming_batch_duration_ms",
          "legendFormat": "{{stream_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["pipeline", "kafka", "spark", "airflow"],
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "title": "MeliSimLake — Pipeline Health",
  "uid": "melisimlake-pipeline",
  "version": 1
}
